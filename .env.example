# Copy this file to .env and fill in your own values.
# Get these from your Cloudinary dashboard: https://console.cloudinary.com/settings/api-keys
#
# Option A — one line (the dashboard shows this near the top of that page —
# make sure you copy the REAL key/secret, not the <api_key>/<api_secret>
# placeholder text shown before you reveal them):
CLOUDINARY_URL=

# Option B — same thing as three separate values, if you prefer:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Leave these blank to use the defaults (SQLite file storage, port 4000).
# PORT=4000
